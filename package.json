{
	"name": "sokos-up-attestasjon",
	"version": "1.0.0",
	"description": "Arbeidsflate for attestasjon i Utbetalingsportalen",
	"type": "module",
	"scripts": {
		"dev": "vite --mode mock",
		"dev:backend": "vite --mode backend",
		"dev:backend-q1": "vite --mode backend-q1",
		"build": "tsc && vite build",
		"playwright": "playwright test",
		"vitest": "vitest",
		"vitest:ui": "vitest --ui",
		"vitest:coverage": "vitest --coverage",
		"biome:check": "biome check --files-ignore-unknown=true",
		"biome:fix": "biome check --write --no-errors-on-unmatched",
		"stylelint:check": "stylelint '**/*.css'",
		"stylelint:fix": "stylelint '**/*.css' --fix",
		"prepare": "husky",
		"pnpm:resolve": "node scripts/resolve-pnpm-version.mjs"
	},
	"dependencies": {
		"@grafana/faro-web-sdk": "2.8.1",
		"@hookform/resolvers": "5.4.0",
		"@navikt/aksel-icons": "7.40.0",
		"@navikt/ds-css": "7.40.0",
		"@navikt/ds-react": "7.40.0",
		"axios": "1.18.1",
		"dayjs": "1.11.21",
		"react": "19.2.7",
		"react-dom": "19.2.7",
		"react-hook-form": "7.80.0",
		"react-router": "8.1.0",
		"swr": "2.4.2",
		"zod": "4.4.3",
		"zustand": "5.0.14"
	},
	"devDependencies": {
		"@axe-core/playwright": "4.12.1",
		"@biomejs/biome": "2.5.1",
		"@navikt/aksel-stylelint": "7.40.0",
		"@playwright/test": "1.61.1",
		"@testing-library/jest-dom": "6.9.1",
		"@testing-library/react": "16.3.2",
		"@types/node": "26.1.0",
		"@types/react": "19.2.17",
		"@types/react-dom": "19.2.3",
		"@vitejs/plugin-react": "6.0.3",
		"@vitest/browser-playwright": "4.1.9",
		"@vitest/coverage-istanbul": "4.1.9",
		"@vitest/ui": "4.1.9",
		"husky": "9.1.7",
		"lint-staged": "17.0.8",
		"msw": "2.14.6",
		"stylelint": "17.14.0",
		"stylelint-config-standard": "40.0.0",
		"typescript": "6.0.3",
		"vite": "8.1.0",
		"vite-plugin-css-injected-by-js": "5.0.1",
		"vitest": "4.1.9"
	},
	"msw": {
		"workerDirectory": [
			"public"
		]
	},
	"stylelint": {
		"extends": [
			"stylelint-config-standard",
			"@navikt/aksel-stylelint/recommended"
		],
		"rules": {
			"aksel/design-token-no-global-override": [
				true,
				{
					"severity": "warning"
				}
			],
			"selector-class-pattern": null
		},
		"ignoreFiles": [
			"dist/**/*",
			"playwright-report/**/*"
		]
	},
	"lint-staged": {
		"*.{js,ts,cjs,mjs,d.cts,d.mts,jsx,tsx,json,jsonc}": "biome check --write --no-errors-on-unmatched",
		"*.css": "stylelint --fix"
	},
	"engines": {
		"pnpm": ">=11.7.0",
		"node": ">=24.14.1"
	},
	"packageManager": "pnpm@11.7.0+sha512.19cc852c120c7125760f2443ee6be0ca5b40f9f50598de1a09a1f177503e010e57c23c77646e01e761de59bf874fb22a3398c33ab9691fc13eb946b6f0f4d620"
}
